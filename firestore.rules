rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidHistory(data) {
      return data.userId == request.auth.uid &&
             data.originalText is string &&
             data.transliteratedText is string &&
             data.targetLanguage is string &&
             data.type in ['text', 'pdf', 'image'];
    }

    match /history/{historyId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidHistory(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false; // History is immutable
    }
  }
}
